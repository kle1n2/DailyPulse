---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

const {
  title = "DailyPulse · 每日脉搏",
  description = "AI 驱动的每日新闻与论文聚合站",
  page = "default"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("js-enabled");
    </script>
  </head>
  <body data-page={page}>
    <ClientRouter />
    <div class="page-backdrop" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container topbar">
        <a class="logo" href={import.meta.env.BASE_URL}>
          <span class="logo-mark">DP</span>
          <span class="logo-text">
            <strong>DailyPulse</strong>
            <small>每日脉搏</small>
          </span>
        </a>

        <nav class="nav" aria-label="主导航">
          <a href={import.meta.env.BASE_URL}>今日脉搏</a>
          <a href={`${import.meta.env.BASE_URL}archive/`}>历史归档</a>
        </nav>
      </div>
    </header>

    <main class="main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>DailyPulse 以每日 JSON 报告归档热点新闻与 AI 研究动态。</p>
        <p>更新链路：Feed 抓取 -&gt; 数据清洗 -&gt; 自动发布。</p>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const setupReveal = () => {
          const staged = [...document.querySelectorAll(".scroll-stage")];
          if (!staged.length) {
            return;
          }
          if (reducedMotion || !("IntersectionObserver" in window)) {
            staged.forEach((node) => node.classList.add("is-visible"));
            return;
          }
          const observer = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.18, rootMargin: "0px 0px -8% 0px" }
          );
          staged.forEach((node) => observer.observe(node));
        };

        const setupCountUp = () => {
          const counters = [...document.querySelectorAll("[data-countup]")];
          if (!counters.length) {
            return;
          }
          const animate = (node) => {
            const target = Number(node.getAttribute("data-countup"));
            if (!Number.isFinite(target)) {
              return;
            }
            if (reducedMotion) {
              node.textContent = String(target);
              return;
            }
            const duration = 900;
            const start = performance.now();
            const step = (now) => {
              const progress = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              node.textContent = String(Math.round(target * eased));
              if (progress < 1) {
                requestAnimationFrame(step);
              }
            };
            requestAnimationFrame(step);
          };

          if (!("IntersectionObserver" in window) || reducedMotion) {
            counters.forEach(animate);
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  animate(entry.target);
                  observer.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.5 }
          );
          counters.forEach((node) => observer.observe(node));
        };

        const setupCategoryRhythm = () => {
          const pills = [...document.querySelectorAll("[data-category-pill]")];
          const sections = [...document.querySelectorAll("[data-category-section]")];
          if (!pills.length || !sections.length) {
            return;
          }

          const mark = (id) => {
            for (const pill of pills) {
              const active = pill.getAttribute("data-category-pill") === id;
              pill.classList.toggle("is-active", active);
            }
          };

          if (!("IntersectionObserver" in window)) {
            mark(pills[0]?.getAttribute("data-category-pill") ?? "");
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              const visible = entries
                .filter((entry) => entry.isIntersecting)
                .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
              if (!visible.length) {
                return;
              }
              const id = visible[0].target.getAttribute("data-category-section") ?? "";
              if (id) {
                mark(id);
              }
            },
            { threshold: [0.25, 0.45, 0.65], rootMargin: "-12% 0px -48% 0px" }
          );

          sections.forEach((node) => observer.observe(node));
          mark(pills[0]?.getAttribute("data-category-pill") ?? "");
        };

        const boot = () => {
          setupReveal();
          setupCountUp();
          setupCategoryRhythm();
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", boot, { once: true });
        } else {
          boot();
        }
      })();
    </script>
  </body>
</html>
