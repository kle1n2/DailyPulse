---
// @ts-nocheck
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllItems,
  getCategoryLabel,
  getConfidenceLabel,
  getDisplaySummary,
  getDisplayTitle,
  getQualityFlagLabel,
  getQualityFlags,
  getSelectionReason,
  getSourceTierLabel
} from "../../lib/content.js";

export async function getStaticPaths() {
  const items = await getAllItems();
  return items.map((item) => ({
    params: { id: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
const displayTitle = getDisplayTitle(item);
const displaySummary = getDisplaySummary(item);
const categoryLabel = item.type === "paper" ? "AI 资讯 / 博客" : getCategoryLabel(item.category);
const confidenceLabel = getConfidenceLabel(item);
const tierLabel = getSourceTierLabel(item);
const selectionReason = getSelectionReason(item);
---

<BaseLayout title={`${displayTitle} · DailyPulse`} description={displaySummary} page="detail">
  <article class="article article-detail scroll-stage">
    <p class="article-kicker">Item Detail</p>
    <h1>{displayTitle}</h1>
    <p class="summary article-summary">{displaySummary}</p>

    <div class="meta meta-detail">
      <span>栏目 {categoryLabel}</span>
      <span>来源 {item.source_name}</span>
      <span>{new Date(item.published_at).toLocaleString("zh-CN", { hour12: false })}</span>
      <span>评分 {item.score}</span>
      <span class={`pill-quality pill-${String(item?.confidence_level ?? "unknown").toLowerCase()}`}>
        {confidenceLabel}
      </span>
      <span class="pill-tier">{tierLabel}</span>
    </div>

    <section class="detail-panel scroll-stage">
      <h2>为何入选</h2>
      <p>{selectionReason}</p>
      {
        item?.confidence_score ? (
          <p class="detail-subtle">模型置信分 {item.confidence_score}</p>
        ) : null
      }
    </section>

    {
      getQualityFlags(item).length ? (
        <section class="detail-panel scroll-stage">
          <h2>质量提示</h2>
          <ul class="flags">
            {getQualityFlags(item).map((flag: string) => <li>{getQualityFlagLabel(flag)}</li>)}
          </ul>
        </section>
      ) : null
    }

    <ul class="highlights">
      {(item.highlights_zh ?? []).map((line: string) => <li>{line}</li>)}
    </ul>

    <div class="detail-actions">
      <a class="button-link" href={item.source_url} target="_blank" rel="noopener noreferrer">阅读原文</a>
      <a class="button-link button-link-muted" href={`${import.meta.env.BASE_URL}archive/${item.report_date}/`}>
        返回当日日报
      </a>
    </div>
  </article>
</BaseLayout>
