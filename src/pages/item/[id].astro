---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllItems } from "../../lib/content.js";

export async function getStaticPaths() {
  const items = await getAllItems();
  return items.map((item) => ({
    params: { id: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
---

<BaseLayout title={`${item.title_zh ?? item.title_en} · DailyPulse`} description={item.summary_zh}>
  <article class="article">
    <h1>{item.title_zh ?? item.title_en}</h1>
    <p class="summary">{item.summary_zh}</p>

    <div class="meta">
      <span>栏目：{item.type === "paper" ? "AI 论文/博客" : item.category}</span>
      <span>来源：{item.source_name}</span>
      <span>{new Date(item.published_at).toLocaleString("zh-CN", { hour12: false })}</span>
      <span>评分：{item.score}</span>
    </div>

    <ul>
      {(item.highlights_zh ?? []).map((line) => <li>{line}</li>)}
    </ul>

    <p>
      <a href={item.source_url} target="_blank" rel="noopener noreferrer">阅读原文</a>
      {" · "}
      <a href={`${import.meta.env.BASE_URL}archive/${item.report_date}/`}>返回当日归档</a>
    </p>
  </article>
</BaseLayout>
