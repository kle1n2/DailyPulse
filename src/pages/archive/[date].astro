---
// @ts-nocheck
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsSection from "../../components/NewsSection.astro";
import PaperSection from "../../components/PaperSection.astro";
import {
  CATEGORY_ORDER,
  getCategoryHeadline,
  getCoverageStatusLabel,
  loadAllDailyReports
} from "../../lib/content.js";

export async function getStaticPaths() {
  const reports = await loadAllDailyReports();
  return reports.map((report) => ({
    params: { date: report.date },
    props: { report }
  }));
}

const { report } = Astro.props;
const totalNews = report?.stats?.news_total ?? 0;
const totalPapers = report?.stats?.paper_total ?? 0;
const coverageByCategory = report?.coverage?.category_coverage ?? {};
const newsByCategory = report?.news ?? {};
const qualityByCategory = report?.quality?.category_quality ?? {};
const sourceFailureCount = report?.quality?.sourceFailures?.length ?? 0;
---

<BaseLayout title={`${report.date} · DailyPulse`} description={`DailyPulse ${report.date} 日报归档`} page="archive-day">
  <section class="hero hero-main scroll-stage">
    <div class="hero-content">
      <p class="hero-kicker">Daily Archive</p>
      <h1>{report.date} 日报</h1>
      <p>包含五个中文新闻栏目与 AI 资讯精选，完整内容直接来自当日归档 JSON。</p>
    </div>
    <div class="hero-stats" aria-label="当日统计">
      <div>
        <strong data-countup={totalNews}>{totalNews}</strong>
        <span>新闻条目</span>
      </div>
      <div>
        <strong data-countup={totalPapers}>{totalPapers}</strong>
        <span>AI 资讯</span>
      </div>
      <div>
        <strong>{getCoverageStatusLabel(report.coverage?.overall_status)}</strong>
        <span>覆盖状态</span>
      </div>
      <div>
        <strong data-countup={sourceFailureCount}>{sourceFailureCount}</strong>
        <span>失败源</span>
      </div>
    </div>
  </section>

  {
    CATEGORY_ORDER.map((id) => {
      const coverage = coverageByCategory[id];
      const title = coverage
        ? `${getCategoryHeadline(id)} · ${coverage.available}/${coverage.target}`
        : getCategoryHeadline(id);
      const quality = qualityByCategory[id] ?? {};
      return (
        <NewsSection
          categoryId={id}
          title={title}
          items={newsByCategory[id] ?? []}
          target={report.constraints?.category_targets?.[id] ?? 5}
          mediumCount={quality.medium_confidence_count ?? 0}
          weakSummaryCount={quality.weak_summary_count ?? 0}
        />
      );
    })
  }

  <PaperSection
    items={report.papers ?? []}
    minTarget={report.constraints?.paper_target_min ?? 3}
    maxTarget={report.constraints?.paper_target_max ?? 5}
    mediumCount={report?.quality?.paper_quality?.medium_confidence_count ?? 0}
    weakSummaryCount={report?.quality?.paper_quality?.weak_summary_count ?? 0}
  />
</BaseLayout>
