---
// @ts-nocheck
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsSection from "../components/NewsSection.astro";
import PaperSection from "../components/PaperSection.astro";
import { CATEGORY_ORDER, getCategoryHeadline, getLatestReport } from "../lib/content.js";

const report = await getLatestReport();
const date = report?.date ?? "暂无";
const categories = report?.categories ?? [];
const totalNews = report?.stats?.news_total ?? 0;
const totalPapers = report?.stats?.paper_total ?? 0;
const newsByCategory = report?.news ?? {};
---

<BaseLayout title={`DailyPulse · ${date}`} description="AI 驱动的每日新闻与论文聚合站">
  {
    report ? (
      <>
        <section class="hero hero-main">
          <div class="hero-content">
            <p class="hero-kicker">Daily Briefing</p>
            <h1>DailyPulse · 每日脉搏</h1>
            <p>
              日期 {report.date}。系统聚合五大新闻栏目与中文 AI 资讯，默认每天北京时间 08:00 更新并归档。
            </p>
            <p class="warn">若当天抓取不足，系统保留空位并显示实际条数，不使用旧数据补齐。</p>
          </div>
          <div class="hero-stats" aria-label="当日统计">
            <div>
              <strong>{totalNews}</strong>
              <span>新闻条目</span>
            </div>
            <div>
              <strong>{totalPapers}</strong>
              <span>AI 资讯</span>
            </div>
            <div>
              <strong>{categories.length}</strong>
              <span>追踪栏目</span>
            </div>
          </div>
        </section>

        <section class="category-strip" aria-label="栏目概览">
          {CATEGORY_ORDER.map((id) => {
            const categoryMeta = categories.find((entry) => entry.id === id);
            const available = categoryMeta?.available ?? (newsByCategory[id] ?? []).length;
            const target = categoryMeta?.target ?? 5;
            return (
              <article class="pill-card">
                <h3>{getCategoryHeadline(id)}</h3>
                <p>
                  {available}/{target}
                </p>
              </article>
            );
          })}
        </section>

        {CATEGORY_ORDER.map((id) => {
          const categoryMeta = categories.find((entry) => entry.id === id);
          const target = categoryMeta?.target ?? 5;
          return <NewsSection title={getCategoryHeadline(id)} items={newsByCategory[id] ?? []} target={target} />;
        })}

        <PaperSection items={report.papers ?? []} minTarget={3} maxTarget={5} />
      </>
    ) : (
      <section class="hero hero-main">
        <div class="hero-content">
          <p class="hero-kicker">Daily Briefing</p>
          <h1>DailyPulse · 每日脉搏</h1>
          <p>当前没有可展示的日报数据，请先执行每日数据生成任务。</p>
        </div>
      </section>
    )
  }
</BaseLayout>
