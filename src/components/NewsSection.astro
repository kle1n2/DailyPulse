---
// @ts-nocheck
import { getDisplaySummary, getDisplayTitle } from "../lib/content.js";

const { title, items = [], target = 5 } = Astro.props;
---

<section class="section section-news">
  <div class="section-head">
    <div>
      <p class="section-kicker">News Radar</p>
      <h2>{title}</h2>
    </div>
    <small class="section-count">{items.length}/{target}</small>
  </div>

  {
    items.length === 0 ? (
      <div class="empty-note">今天该栏目暂无可发布内容，下一轮抓取会自动补齐可用条目。</div>
    ) : (
      <div class="news-grid">
        {items.map((item: any, idx: number) => (
          <article class="story-card" style={`--delay:${idx * 45}ms`}>
            <h3>
              <a href={`${import.meta.env.BASE_URL}item/${item.id}/`}>{getDisplayTitle(item)}</a>
            </h3>
            <p class="summary">{getDisplaySummary(item)}</p>
            <div class="meta">
              <span>{item.source_name}</span>
              <span>{new Date(item.published_at).toLocaleString("zh-CN", { hour12: false })}</span>
              <span>评分 {item.score}</span>
              <a href={item.source_url} target="_blank" rel="noopener noreferrer">原文</a>
            </div>
          </article>
        ))}
      </div>
    )
  }
</section>

