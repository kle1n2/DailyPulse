---
// @ts-nocheck
import {
  getConfidenceLabel,
  getDisplaySummary,
  getDisplayTitle,
  getQualityFlagLabel,
  getQualityFlags,
  getSourceTierLabel
} from "../lib/content.js";

const {
  categoryId = "unknown",
  title,
  items = [],
  target = 5,
  mediumCount = 0,
  weakSummaryCount = 0
} = Astro.props;
---

<section class="section section-news scroll-stage" data-category-section={categoryId}>
  <div class="section-head">
    <div>
      <p class="section-kicker">News Radar</p>
      <h2>{title}</h2>
      <p class="section-subtle">按纯度优先策略筛选，中低质量条目不会强行补齐。</p>
    </div>
    <small class="section-count">{items.length}/{target}</small>
  </div>
  <div class="section-quality">
    <span class="quality-chip">中置信 {mediumCount}</span>
    <span class="quality-chip">弱摘要 {weakSummaryCount}</span>
  </div>

  {
    items.length === 0 ? (
      <div class="empty-note">今日严格筛选后该栏目不足目标条数，下一轮抓取会继续补充。</div>
    ) : (
      <div class="news-grid">
        {items.map((item: any, idx: number) => (
          <article class="story-card scroll-stage" style={`--delay:${idx * 45}ms`}>
            <h3>
              <a href={`${import.meta.env.BASE_URL}item/${item.id}/`}>{getDisplayTitle(item)}</a>
            </h3>
            <p class="summary">{getDisplaySummary(item)}</p>
            <div class="meta">
              <span>{item.source_name}</span>
              <span>{new Date(item.published_at).toLocaleString("zh-CN", { hour12: false })}</span>
              <span>评分 {item.score}</span>
              <span class={`pill-quality pill-${String(item?.confidence_level ?? "unknown").toLowerCase()}`}>
                {getConfidenceLabel(item)}
              </span>
              <span class="pill-tier">{getSourceTierLabel(item)}</span>
              <a href={item.source_url} target="_blank" rel="noopener noreferrer">原文</a>
            </div>
            {
              getQualityFlags(item).length ? (
                <ul class="flags">
                  {getQualityFlags(item).map((flag: string) => <li>{getQualityFlagLabel(flag)}</li>)}
                </ul>
              ) : null
            }
          </article>
        ))}
      </div>
    )
  }
</section>
