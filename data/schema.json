{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DailyPulse Daily Report",
  "type": "object",
  "required": [
    "version",
    "date",
    "generated_at",
    "constraints",
    "categories",
    "news",
    "papers",
    "stats"
  ],
  "properties": {
    "version": { "type": "string" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "constraints": {
      "type": "object",
      "required": ["category_targets", "paper_target_min", "paper_target_max"]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "target", "available"]
      }
    },
    "news": {
      "type": "object",
      "required": ["technology", "finance", "world", "ai", "society"]
    },
    "papers": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    },
    "stats": {
      "type": "object",
      "required": ["news_total", "paper_total", "news_counts"]
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": [
        "id",
        "type",
        "category",
        "title_zh",
        "title_en",
        "summary_zh",
        "highlights_zh",
        "source_name",
        "source_url",
        "published_at",
        "score",
        "tags"
      ],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["news", "paper"] },
        "category": { "type": "string" },
        "title_zh": { "type": "string" },
        "title_en": { "type": "string" },
        "summary_zh": { "type": "string" },
        "highlights_zh": { "type": "array", "items": { "type": "string" } },
        "source_name": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "published_at": { "type": "string", "format": "date-time" },
        "score": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
